\docsvlist{
    asinh,acosh,atanh,acoth,asech,acsch,
    arsinh,arcosh,artanh,arcoth,arsech,arcsch,
    arcsinh,arccosh,arctanh,arccoth,arcsech,arccsch,
    sen,tg,cth,senh,tgh,ctgh,
}

% Shortcuts for other mathematical operators
\def\do#1{\csdef{#1}{\opbraces{\operatorname{#1}}}}
\docsvlist{
    erf,erfc,erfi,
    Re,Im,arg,Arg,sign,
    gcd,lcm,ord,
    id,Hom,End,Ann,Frac,
    im,ran,Ran,ker,Ker,coker,Coker,rank,rk,nul,
