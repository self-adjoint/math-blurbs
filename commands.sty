% Blackboard bold, e.g. \N is a shortcut for \mathbb{N}
% This auto-sizes parentheses and brackets, e.g. ring extensions ℤ[√2] or field extensions ℚ(√2)
\newcommand*{\N}{\opbraces{\mathbb{N}}}
\newcommand*{\Z}{\opbraces{\mathbb{Z}}}
\newcommand*{\Q}{\opbraces{\mathbb{Q}}}
\newcommand*{\R}{\opbraces{\mathbb{R}}}
\newcommand*{\C}{\opbraces{\mathbb{C}}}
\newcommand*{\F}{\opbraces{\mathbb{F}}}
\newcommand*{\K}{\opbraces{\mathbb{K}}}

% \spn is defined separately as the syntax "spn" is different from the output "span"
% \span is already defined in the LaTeX kernel. This is a fundamental LaTeX command, DO NOT overwrite it!
\newcommand{\spn}{\opbraces{\operatorname{span}}}
% Same for char
\newcommand{\chr}{\opbraces{\operatorname{char}}}

% Set-builder notation {a|b} with auto-sizing brackets
\newcommand*{\setbuild}[2]{\left\{#1\,\middle|\,#2\right\}}
\newcommand*{\bsetbuild}[2]{\left[#1\,\middle|\,#2\right]}

% \fsize stores the current font size but is expandable (and can be called later without using \makeatletter and \makeatother)
\def\fsize{\dimexpr\f@size pt\relax}
